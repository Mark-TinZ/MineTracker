# Example environment configuration for mc_ping_bot

# Bot token obtained from BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram user ID of the bot owner (optional, default 0)
OWNER_ID=123456789

# Database Settings
# For local development with SQLite: sqlite+aiosqlite:///./bot.db
# For Docker with PostgreSQL: postgresql+asyncpg://minetracker_user:minetracker_password@postgres:5432/minetracker
DATABASE_URL=postgresql+asyncpg://minetracker_user:minetracker_password@localhost:5432/minetracker

# Redis Settings
REDIS_URL=redis://localhost:6379/0

# App Settings
LOG_LEVEL=INFO
DEFAULT_LANGUAGE=ru
UPDATE_INTERVAL=60

# Throttling and Timeout
MINECRAFT_PING_TIMEOUT=5
THROTTLE_RATE_LIMIT=5
THROTTLE_WINDOW=10

# Comma‑separated list of supported languages
SUPPORTED_LANGUAGES=ru,en
